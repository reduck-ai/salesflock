# salesflock environment. Copy to .env (auto-loaded by both binaries: `sflock`, `leads`).
# Every var here is OPTIONAL — the tool runs out of the box. Auth for reduck, Notion and
# HubSpot comes from each tool's own CLI session (keychain), never from this file.

# --- Lead store (the `leads` binary) ---

# Where enriched leads land: "jsonl" (default) or "notion".
LEADS_ADAPTER="jsonl"

# jsonl adapter — output path.
LEADS_FILE="leads.jsonl"

# notion adapter — the People database / data-source id.
# REQUIRED when LEADS_ADAPTER="notion".
NOTION_PEOPLE_DS=""

# --- Judge LLM (the `leads` binary) ---

# Which backend judges leads: "google" (default) or "bedrock" (Claude on Amazon Bedrock).
LLM_PROVIDER="google"

# Optional model override. Defaults: gemini-3.5-flash (google) / us.anthropic.claude-sonnet-4-6 (bedrock).
# LLM_MODEL=""

# google: Gemini API key (Gemini has no CLI session, so this one key lives here).
# GEMINI_API_KEY=""

# bedrock: creds come from the AWS CLI session (SSO) — set only to override your defaults.
# LLM_PROVIDER="bedrock"
# AWS_PROFILE="conception"
# AWS_REGION="us-east-1"          # Bedrock + the us.anthropic.* model live here, not eu-west-3
# aws sso login --profile conception

# --- Review app (the `leads` binary) ---

# Base URL of the deployed Decisions review app. When set, `leads list` / `show` / the qualify
# and engage tools return an `open` link (`<url>/<decision-id>`) a human clicks to review the
# decision in the UI. Unset → no link (the decisions still print).
# SALESFLOCK_APP_URL="https://your-app.vercel.app"

# --- Advanced overrides ---

# Path to a patched reduck CLI build (default: the bundled @reduck-ai/cli).
# REDUCK_BIN=""

# HubSpot private-app token (default: the `hubspot` CLI's OAuth session).
# HUBSPOT_TOKEN=""
