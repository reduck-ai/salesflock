# Auth.js — `npx auth secret` generates AUTH_SECRET; the Google pair comes from
# your OAuth client (see APP.md).
AUTH_SECRET=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Who may enter. Comma-separated Google account emails.
ALLOWED_EMAILS=you@gmail.com

# Notion internal-integration token + the Decisions data-source id it is shared with.
NOTION_TOKEN=
NOTION_DECISIONS_DS=
