# Always required — signs sessions (incl. the secret-link cookie). `npx auth secret`.
AUTH_SECRET=

# Which gate. "google" (default) or "secret-link". See APP.md → Auth modes.
AUTH_PROVIDER=google

# google mode — OAuth client (AUTH_GOOGLE_*) plus exactly one policy below.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
ALLOWED_EMAILS=you@gmail.com   # the invite list, comma-separated
ALLOWED_DOMAINS=               # OR anyone @these domains (the Workspace case)

# secret-link mode — the shareable link is /?key=<ACCESS_KEY>. No Google, no policy.
ACCESS_KEY=

# Notion internal-integration token + the Decisions data-source id it is shared with.
NOTION_TOKEN=
NOTION_DECISIONS_DS=
