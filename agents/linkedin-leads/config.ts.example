// Copy to config.ts and fill in. Binds this agent to a store: which destination, which
// table each logical model maps to, and its named prompt rows. `sflock pull --agent
// linkedin-leads` reads it to regenerate schema/*.ts; the runtime reads it at run time.

import type { AgentConfig } from "../../src/stores/index.js";

export default {
	destination: "notion", // a key of STORES (notion | hubspot); notion is the full store today
	models: {
		// logical model name → the store's table/object id (a Notion data-source id here)
		People: "<People data source id>",
		Companies: "<Companies data source id>",
		Leads: "<Leads data source id>",
		Sourcing: "<Sourcing data source id>",
		Decisions: "<Decisions data source id>",
		Prompts: "<Prompts data source id>"
	},
	// the Decision relation naming this agent's pipeline entity — the runtime binds a Decision to it
	// and the review app moves that entity's Status on confirm (e.g. "Lead", "X Engagement")
	entity: "<the Decision→entity relation name>",
	prompts: { qualify: "<the Name of the qualification prompt row in the Prompts table>" }
} satisfies AgentConfig;
